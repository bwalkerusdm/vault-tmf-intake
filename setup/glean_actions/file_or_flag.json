{
  "openapi": "3.0.0",
  "info": {
    "title": "File or Flag TMF Document",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://vault-tmf-intake.vercel.app"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/etmf/actions/file_or_flag.py": {
      "post": {
        "operationId": "fileOrFlag",
        "summary": "Run the deterministic gate on the agent's findings; file the document to Vault or hold it.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "box_file_id": {
                    "type": "string",
                    "description": "Box file ID of the document"
                  },
                  "filename": {
                    "type": "string",
                    "description": "Original filename including extension"
                  },
                  "findings": {
                    "type": "object",
                    "description": "The five structured findings. Keys: tmf_content {is_tmf bool, zone, artifact, confidence 0-100}; classification {type__v, subtype__v, classification__v, tmf_rm_v3, confidence 0-100} (must be a triple from getTaxonomy); phi_pii {status 'clear'|'findings', findings:[{identifier_type, belongs_to, location}]}; alcoa_plus {attributes:{attributable,legible,contemporaneous,original,accurate,complete,consistent,enduring,available - each {verdict 'pass'|'flag', basis}}}; record_resolution {study_ref, country_ref, site_ref (raw refs read from the doc), study__v, study_country__v, site__v, all_resolved, parent_validated, scope}.",
                    "properties": {},
                    "additionalProperties": true
                  }
                },
                "required": [
                  "box_file_id",
                  "filename",
                  "findings"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "disposition": {
                      "type": "string",
                      "description": "filed | held"
                    },
                    "status": {
                      "type": "string",
                      "description": "clean | flagged | not_tmf | out_of_scope | unprocessable"
                    },
                    "checks_hash": {
                      "type": "string"
                    },
                    "vault_document_id": {
                      "type": "string"
                    },
                    "vault_link": {
                      "type": "string"
                    },
                    "disposition_kind": {
                      "type": "string"
                    },
                    "reasons": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "flag_rules": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "scope": {
                      "type": "string"
                    },
                    "scope_reason": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
