{
  "openapi": "3.0.0",
  "info": {
    "title": "List Box Inbox",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://vault-tmf-intake.vercel.app"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/etmf/actions/list_inbox.py": {
      "post": {
        "operationId": "listInbox",
        "summary": "List the documents waiting in the Box 1-Inbox folder.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "documents": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "box_file_id": {
                            "type": "string"
                          },
                          "filename": {
                            "type": "string"
                          },
                          "is_archive": {
                            "type": "boolean"
                          }
                        }
                      }
                    },
                    "count": {
                      "type": "integer"
                    },
                    "archives": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
