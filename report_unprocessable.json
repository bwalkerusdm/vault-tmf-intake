{
  "openapi": "3.0.0",
  "info": {
    "title": "Expand Archive",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://vault-tmf-intake.vercel.app"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/etmf/actions/expand_archive.py": {
      "post": {
        "operationId": "expandArchive",
        "summary": "Unpack a zip/tar archive in the inbox into individual documents.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "box_file_id": {
                    "type": "string",
                    "description": "Box file ID of the archive"
                  },
                  "filename": {
                    "type": "string",
                    "description": "Archive filename including extension"
                  }
                },
                "required": [
                  "box_file_id",
                  "filename"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "archive": {
                      "type": "string"
                    },
                    "extracted": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "extracted_count": {
                      "type": "integer"
                    },
                    "skipped": {
                      "type": "array",
                      "items": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
